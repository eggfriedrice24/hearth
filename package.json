{
  "name": "@hearth/monorepo",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@types/node": "^22.15.0",
      "tsdown": "^0.20.3",
      "typescript": "^5.7.3",
      "vitest": "^4.0.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "dev:server": "turbo run dev --filter=@hearth/server",
    "dev:web": "turbo run dev --filter=@hearth/web",
    "dev:desktop": "turbo run dev --filter=@hearth/desktop",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint --report-unused-disable-directives",
    "lint:fix": "oxlint --fix --report-unused-disable-directives",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "turbo run test",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist apps/*/dist-electron packages/*/dist .turbo apps/*/.turbo packages/*/.turbo"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "turbo": "^2.3.3",
    "vitest": "catalog:"
  },
  "engines": {
    "bun": ">=1.3.9"
  },
  "packageManager": "bun@1.3.10"
}
